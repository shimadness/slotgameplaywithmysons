{
  "name": "triple-slot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "TRIPLE SLOT — an original browser slot game (puzzle x slot), built to play with my sons.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "rtp": "npx tsx rtp.mjs",
    "sync": "npm run build && npx cap sync",
    "ios": "npm run build && npx cap sync ios && npx cap open ios"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/status-bar": "^8.0.2"
  }
}
